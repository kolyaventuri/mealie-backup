# --- Mealie ---
# Base URL of your Mealie instance (no trailing slash)
MEALIE_URL=http://mealie:9000

# API token from Mealie → User Profile → API Tokens
MEALIE_API_KEY=your-mealie-api-key

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name

# Key prefix for uploaded backups (include trailing slash)
S3_PREFIX=mealie-backups/

# --- Schedule ---
# Cron expression (default: Sundays at 02:00)
CRON_SCHEDULE=0 2 * * 0

# Set to "true" to run a backup immediately when the container starts
RUN_ON_START=false

# How long to wait for Mealie to be reachable before giving up (seconds, default: 180)
# Only used when RUN_ON_START=true
STARTUP_TIMEOUT=180

# --- Retention ---
# Delete S3 backups older than this many days (0 = disabled)
S3_RETENTION_DAYS=90
